#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pattern or test to apply to criteria_range1."
msgstr "Obrazac ili test koji se primjenjuje na criteria_range1."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pattern or test to apply to criteria_range2."
msgstr "Obrazac ili test koji se primjenjuje na criteria_range2."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pattern or test to apply to range."
msgstr "Obrazac ili test koji se primjenjuje na opseg."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The percentile whose value within data will be calculated and returned."
msgstr ""
"Percentil čija će vrijednost unutar podataka biti izračunata i vraćena."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
