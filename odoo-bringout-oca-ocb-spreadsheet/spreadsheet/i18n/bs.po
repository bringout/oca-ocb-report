"The percentile, exclusive of 0 and 1, whose value within 'data' will be "
"calculated and returned."
msgstr ""
"Percentil, isključujući 0 i 1, čija će vrijednost unutar 'data' biti "
"izračunata i vraćena."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period (%(period)s) must be less than or equal life (%(life)s)."
msgstr "Period (%(period)s) mora biti manji ili jednak vijeku (%(life)s)."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period (%(period)s) must be less than or equal to %(lifeLimit)s."
msgstr "Period (%(period)s) mora biti manji ili jednak %(lifeLimit)s."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period for which you want to view the interest payment."
msgstr "Period za koji želite vidjeti uplatu kamate."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The period must be between 1 and number_of_periods (%s)"
msgstr "Period mora biti između 1 i number_of_periods (%s)"

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The periods_by_year (%s) must be strictly positive."
msgstr "periods_by_year (%s) mora biti strogo pozitivan."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pivot cannot be created because cell %s contains a reserved value"
msgstr "Pivot se ne može kreirati jer ćelija %s sadrži rezervisanu vrijednost"

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pivot cannot be created because cell %s contains an error"
msgstr "Pivot se ne može kreirati jer ćelija %s sadrži grešku"

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pivot cannot be created because cell %s is empty"
msgstr "Pivot se ne može kreirati jer je ćelija %s prazna"

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The pivot cannot be created because the dataset is missing."
msgstr "Pivot se ne može kreirati jer nedostaje skup podataka."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The position (%s) must be greater than or equal to 1."
msgstr "Pozicija (%s) mora biti veća ili jednaka 1."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The present value of the investment."
msgstr "Sadašnja vrijednost investicije."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price at which the security is bought per 100 face value."
msgstr ""
"Cijena po kojoj se hartija od vrijednosti kupuje po 100 nominalne "
"vrijednosti."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price at which the security is bought."
msgstr "Cijena po kojoj se hartija od vrijednosti kupuje."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price quotation given as a decimal value."
msgstr "Kotacija cijene data kao decimalna vrijednost."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The price quotation given using fractional decimal conventions."
msgstr "Kotacija cijene data koristeći decimalne konvencije razlomaka."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The purchase_date (%(purchaseDate)s) must be before the first_period_end "
"(%(firstPeriodEnd)s)."
msgstr ""
"purchase_date (%(purchaseDate)s) mora biti prije first_period_end "
"(%(firstPeriodEnd)s)."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The purchase_date (%s) must be positive or null."
msgstr "purchase_date (%s) mora biti pozitivan ili null."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
