msgstr "occurrenceNumber (%s) mora biti pozitivan ili null."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The one-dimensional array to be searched."
msgstr "Jednodimenzionalni niz koji se pretražuje."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The order of the polynomial to fit the data, between 1 and 6."
msgstr "Red polinoma za podešavanje podataka, između 1 i 6."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
