msgstr "Početna tačka od koje se broje ofset redovi i kolone."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The starting unit, the unit currently assigned to value"
msgstr "Početna jedinica, jedinica trenutno dodijeljena vrijednosti"

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The starting_at (%s) must be greater than or equal to 1."
msgstr "starting_at (%s) mora biti veći ili jednak 1."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
