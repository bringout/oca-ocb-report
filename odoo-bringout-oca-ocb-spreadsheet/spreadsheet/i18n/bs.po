msgstr "Opseg je nevažeći."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range is out of bounds."
msgstr "Opseg je izvan granica."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range is out of the sheet"
msgstr "Opseg je izvan lista"

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range of cells from which the maximum will be determined."
msgstr "Opseg ćelija iz kojeg će se odrediti maksimum."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range of cells from which the minimum will be determined."
msgstr "Opseg ćelija iz kojeg će se odrediti minimum."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range of cells from which the number of unique values will be counted."
msgstr "Opseg ćelija iz kojeg će se brojati broj jedinstvenih vrijednosti."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range of cells from which the values are returned."
msgstr "Opseg ćelija iz kojeg se vraćaju vrijednosti."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range of cells over which to evaluate criterion1."
msgstr "Opseg ćelija nad kojim se evaluira criterion1."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range or reference for which you want the subtotal."
msgstr "Opseg ili referenca za koju želite međuzbir."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range representing the array or matrix of dependent data."
msgstr "Opseg koji predstavlja niz ili matricu zavisnih podataka."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range representing the array or matrix of independent data."
msgstr "Opseg koji predstavlja niz ili matricu nezavisnih podataka."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range representing the array or matrix of observed data."
msgstr "Opseg koji predstavlja niz ili matricu opservisanih podataka."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range representing the array or matrix of predicted data."
msgstr "Opseg koji predstavlja niz ili matricu predviđenih podataka."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range that is tested against criterion."
msgstr "Opseg koji se testira u odnosu na kriterijum."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to average."
msgstr "Opseg za usrednjavanje."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range to average. If not included, criteria_range is used for the "
"average instead."
msgstr ""
"Opseg za usrednjavanje. Ako nije uključen, criteria_range se koristi za "
"usrednjavanje."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to be summed, if different from range."
msgstr "Opseg za sabiranje, ako je različit od opsega."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to be transposed."
msgstr "Opseg za transponovanje."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to check against criterion."
msgstr "Opseg za provjeru u odnosu na kriterijum."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to check against criterion1."
msgstr "Opseg za provjeru u odnosu na criterion1."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range to consider for the search. The first column in the range is "
"searched for the key specified in search_key."
msgstr ""
"Opseg za razmatranje pretrage. Prva kolona u opsegu se pretražuje za ključem"
" navedenim u search_key."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The range to consider for the search. The first row in the range is searched"
" for the key specified in search_key."
msgstr ""
"Opseg za razmatranje pretrage. Prvi red u opsegu se pretražuje za ključem "
"navedenim u search_key."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to constrain."
msgstr "Opseg za ograničavanje."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to sum."
msgstr "Opseg za sabiranje."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range to wrap."
msgstr "Opseg za omotavanje."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range which is tested against criterion."
msgstr "Opseg koji se testira u odnosu na kriterijum."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range whose column count will be returned."
msgstr "Opseg čiji se broj kolona vraća."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The range whose row count will be returned."
msgstr "Opseg čiji se broj redova vraća."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rank from largest to smallest of the element to return."
msgstr "Rang od najvećeg do najmanjeg elementa koji se vraća."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rank from smallest to largest of the element to return."
msgstr "Rang od najmanjeg do najvećeg elementa koji se vraća."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rate at which the investment grows each period."
msgstr "Stopa po kojoj investicija raste svakog perioda."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The redemption amount per 100 face value, or par."
msgstr "Iznos otkupa po 100 nominalne vrijednosti."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The reference to the cell."
msgstr "Referenca na ćeliju."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The regular expression pattern to match against the text."
msgstr "Obrazac regularnog izraza za podudaranje s tekstom."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The return (as a percentage) earned on reinvestment of income received from "
"the investment."
msgstr ""
"Prinos (kao procenat) zarađen reinvestiranjem prihoda primljenog od "
"investicije."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The return_mode (%s) must be 0, 1 or 2."
msgstr "return_mode (%s) mora biti 0, 1 ili 2."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The returned value if condition1 is TRUE."
msgstr "Vraćena vrijednost ako je condition1 TRUE."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The row index of the value to be returned, where the first row in range is "
"numbered 1."
msgstr ""
"Indeks reda vrijednosti koja se vraća, gdje je prvi red u opsegu numerisan "
"1."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The row number of the cell reference. "
msgstr "Broj reda reference ćelije. "

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rows argument (%s) must be strictly positive."
msgstr "Argument rows (%s) mora biti strogo pozitivan."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The rows arguments (%s) must be greater or equal than the number of rows of "
"the array."
msgstr "Argumenti rows (%s) moraju biti veći ili jednaki broju redova niza."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rows arguments must be between -%s and %s (got %s), excluding 0."
msgstr ""
"Argumenti rows moraju biti između -%s i %s (dobiveno %s), isključujući 0."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rows indexes of the rows to be returned."
msgstr "Indeksi redova koji se vraćaju."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The rule is invalid for an unknown reason."
msgstr "Pravilo je nevažeće iz nepoznatog razloga."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The salvage (%(salvage)s) must be smaller or equal than the cost (%(cost)s)."
msgstr "salvage (%(salvage)s) mora biti manji ili jednak cijeni (%(cost)s)."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The search and match mode combination is not supported for XLOOKUP "
"evaluation."
msgstr ""
"Kombinacija režima pretrage i podudaranja nije podržana za XLOOKUP "
"evaluaciju."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The search method is a number 1, 0 or -1 indicating which value to return. 1"
" finds the largest value less than or equal to search_key when range is "
"sorted in ascending order. 0 finds the exact value when range is unsorted. "
"-1 finds the smallest value greater than or equal to search_key when range "
"is sorted in descending order."
msgstr ""
"Metoda pretrage je broj 1, 0 ili -1 koji označava koja se vrijednost vraća. "
"1 nalazi najveću vrijednost manju ili jednaku search_key kada je opseg "
"sortiran u rastućem redoslijedu. 0 nalazi tačnu vrijednost kada opseg nije "
"sortiran. -1 nalazi najmanju vrijednost veću ili jednaku search_key kada je "
"opseg sortiran u opadajućem redoslijedu."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second component of the time."
msgstr "Komponenta sekundi vremena."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second matrix in the matrix multiplication operation."
msgstr "Druga matrica u operaciji množenja matrica."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The second number to compare."
msgstr "Drugi broj za poređenje."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The settlement date (%(settlement)s) must at most one year after the "
"maturity date (%(maturity)s)."
msgstr ""
"Datum poravnanja (%(settlement)s) mora biti najviše godinu dana nakon datuma"
" dospijeća (%(maturity)s)."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The settlement date (%(settlement)s) must be greater or equal to the issue "
"date (%(issue)s)."
msgstr ""
"Datum poravnanja (%(settlement)s) mora biti veći ili jednak datumu izdavanja"
" (%(issue)s)."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The settlement date (%(settlement)s) must be strictly greater than the issue"
" date (%(issue)s)."
msgstr ""
"Datum poravnanja (%(settlement)s) mora biti strogo veći od datuma izdavanja "
"(%(issue)s)."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The settlement date of the security, the date after issuance when the "
"security is delivered to the buyer."
msgstr ""
"Datum poravnanja hartije od vrijednosti, datum nakon izdavanja kada se "
"hartija isporučuje kupcu."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The single period within life for which to calculate depreciation."
msgstr "Pojedinačni period unutar vijeka za koji se izračunava amortizacija."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The source text."
msgstr "Izvorni tekst."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The start date of the period from which to calculate the number of net "
"working days."
msgstr "Početni datum perioda iz kojeg se izračunava broj neto radnih dana."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The start date to consider in the calculation."
msgstr "Početni datum za razmatranje u izračunu."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The start date to consider in the calculation. Must be a reference to a cell"
" containing a DATE, a function returning a DATE type, or a number."
msgstr ""
"Početni datum za razmatranje u izračunu. Mora biti referenca na ćeliju koja "
"sadrži DATE, funkciju koja vraća DATE tip, ili broj."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The start date to consider in the calculation. Must be a reference to a cell"
" containing a date, a function returning a date type, or a number."
msgstr ""
"Početni datum za razmatranje u izračunu. Mora biti referenca na ćeliju koja "
"sadrži datum, funkciju koja vraća datumski tip, ili broj."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The start of the date range."
msgstr "Početak opsega datuma."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid ""
"The start_period (%(start)s) must be smaller or equal to the end_period "
"(%(end)s)."
msgstr ""
"start_period (%(start)s) mora biti manji ili jednak end_period (%(end)s)."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
msgid "The start_period (%s) must be positive or null."
msgstr "start_period (%s) mora biti pozitivan ili null."

#. module: spreadsheet
#: code:addons/spreadsheet/static/src/o_spreadsheet/o_spreadsheet.js:0
